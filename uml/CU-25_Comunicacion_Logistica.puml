@startuml
left to right direction
skinparam BackgroundColor white

actor "Cliente" as Cliente
boundary "checkoutForm" as Form
control "logisticaControl" as Control
database "Pedido" as DB

Cliente -> Form : 1: ingresarZona()\n2: seleccionarEnvio()
Form -> Control : 1.1: obtenerMetodos()\n2.1: calcularCostoEnvio()
Control -> DB : 2.2: actualizarCostoPedido()
@enduml
