@startuml
left to right direction
allowmixing
skinparam classAttributeIconSize 0
skinparam BackgroundColor white

actor "Cliente" as Cliente

class "Formulario de Historial" as Form <<Interface>> {
  + Pedido
  + Calificacion
  + Resena
  + EnviarCalificacion()
}
class "ResenaController" as Control {
  + validarEstado()
  + procesarResena()
  + guardarResena()
}

class "ClienteEntity" as CEntity {
  + Integer id;
  + String nombre;
  + String correo;
  constructor
  setter
  getter
}

class "ProductoEntity" as PEntity {
  + Integer id;
  + String nombre;
  constructor
  setter
  getter
}

class "ResenaEntity" as REntity {
  + Integer id;
  + Integer calificacion;
  + String comentario;
  + Date fecha;
  constructor
  setter
  getter
}

Cliente -- Form
Form -- Control
Control -- REntity
Control -- CEntity

CEntity "1..1" -- "1..*" REntity
REntity "1..*" -- "1..1" PEntity

@enduml
